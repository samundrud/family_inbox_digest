# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Gmail (the dedicated family forwarding inbox)
FAMILY_INBOX_EMAIL=your-family-inbox@gmail.com
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# JSONBin (https://jsonbin.io — free tier)
JSONBIN_BIN_ID=your-bin-id-here
JSONBIN_API_KEY=$2a$10$...

# Weekly digest email recipients (comma-separated)
DIGEST_RECIPIENTS=parent1@gmail.com,parent2@gmail.com

# Parent email accounts that forward school/activity emails to the family inbox (comma-separated)
# Emails NOT from these addresses are ignored (filters out system/spam emails)
ALLOWED_FORWARDERS=parent1@gmail.com,parent2@gmail.com

# Free-text family context passed to Claude to improve analysis accuracy
# Describe children's schools and activity providers, and your city/region
FAMILY_CONTEXT=The family has children at School Name, Daycare Name, and Activity Provider in City, Province/State.

# Linear (for ticket management — only needed for linear_setup.py)
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=FAM