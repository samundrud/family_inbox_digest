# JSONBin (https://jsonbin.io — must match backend/.env values)
VITE_JSONBIN_BIN_ID=your-bin-id-here
# Escape every $ with \$ — Vite runs dotenv-expand which treats $X as a variable reference
VITE_JSONBIN_API_KEY=\$2a\$10\$...
# PIN gate — required to make any write action on the dashboard
VITE_APP_PIN=1234